# ── Environment ────────────────────────────────────────────────────────────────
# "local" → uses LOCAL_DATABASE_URL (if set) and ChromaDB
# "production" → uses DATABASE_URL and Upstash Vector
ENVIRONMENT=local

# ── Database ───────────────────────────────────────────────────────────────────
# Production Neon branch
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
# Local/dev Neon branch (only used when ENVIRONMENT=local)
LOCAL_DATABASE_URL=postgresql://user:password@host/neondb-dev?sslmode=require

# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-4o-mini

# ── Vector store ───────────────────────────────────────────────────────────────
# ChromaDB (local, used when Upstash vars are absent)
CHROMA_DIR=./chroma_data

# Upstash Vector (production, takes over when both vars are set)
UPSTASH_VECTOR_REST_URL=https://your-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-token

# ── Server ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
